# .env  —  copy this file, fill in real values, NEVER commit to git
# ──────────────────────────────────────────────────────────────

# ── Angel One SmartAPI ────────────────────────────────────────
ANGEL_API_KEY=YOUR_API_KEY_HERE
ANGEL_CLIENT_ID=YOUR_CLIENT_ID_HERE
ANGEL_PASSWORD=YOUR_LOGIN_PASSWORD_HERE
ANGEL_TOTP_SECRET=YOUR_TOTP_BASE32_SECRET_HERE

# ── Telegram Bot (optional — alerts disabled if blank) ────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
